<Window x:Class="PhoneCallCost.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Стоимость телефонного разговора" Height="400" Width="350">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Стоимость телефонного разговора" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Длительность (мин)" Margin="5"/>
        <TextBox x:Name="DurationTextBox" Grid.Row="1" Grid.Column="1" Margin="5" Width="120" HorizontalAlignment="Left"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Цена (мин)" Margin="5"/>
        <TextBox x:Name="PricePerMinuteTextBox" Grid.Row="2" Grid.Column="1" Margin="5" Width="120" HorizontalAlignment="Left"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Стоимость" Margin="5"/>
        <TextBox x:Name="CostTextBox" Grid.Row="3" Grid.Column="1" Margin="5" Width="120" HorizontalAlignment="Left" IsReadOnly="True" Background="LightGray"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="День недели" Margin="5,10,5,5"/>
        <StackPanel Grid.Row="4" Grid.Column="1" Margin="5,5,0,0">
            <RadioButton x:Name="MondayRadio" Content="понедельник" GroupName="DayOfWeek" Margin="0,2"/>
            <RadioButton x:Name="TuesdayRadio" Content="вторник" GroupName="DayOfWeek" Margin="0,2"/>
            <RadioButton x:Name="WednesdayRadio" Content="среда" GroupName="DayOfWeek" Margin="0,2"/>
            <RadioButton x:Name="ThursdayRadio" Content="четверг" GroupName="DayOfWeek" Margin="0,2"/>
            <RadioButton x:Name="FridayRadio" Content="пятница" GroupName="DayOfWeek" Margin="0,2"/>
            <RadioButton x:Name="SaturdayRadio" Content="суббота" GroupName="DayOfWeek" Margin="0,2"/>
            <RadioButton x:Name="SundayRadio" Content="воскресенье" GroupName="DayOfWeek" Margin="0,2"/>
        </StackPanel>

        <Button x:Name="CalculateButton" Grid.Row="5" Grid.ColumnSpan="2" Content="Вычислить" Width="100" Height="30" HorizontalAlignment="Center" Margin="0,15,0,0" Click="CalculateButton_Click"/>
    </Grid>
</Window>